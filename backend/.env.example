# 적조예측 플랫폼 API 키 설정 예시
# 이 파일을 복사해서 .env 로 저장한 뒤 실제 키 값으로 채우세요.
# .env 파일은 절대 Git에 커밋하지 마세요. (.gitignore 처리됨)

# 공공데이터포털 (data.go.kr) — 해양환경공단/해양조사원 등 통합 인증키
DATA_GO_KR_KEY=여기에_본인_키_입력

# 기상자료개방포털 (data.kma.go.kr) — 기상청 해양기상부이/ASOS 일사량/풍속
KMA_API_KEY=여기에_본인_키_입력

# (선택) Copernicus Marine Service — 위성 클로로필-a
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
